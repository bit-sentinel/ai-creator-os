# AI Creator OS — Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.

# ── Anthropic / Claude ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_TEMPERATURE=0.7

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Apify ─────────────────────────────────────────────────────────────────────
APIFY_API_TOKEN=apify_api_...

# ── Meta / Instagram ──────────────────────────────────────────────────────────
INSTAGRAM_APP_ID=1234567890
INSTAGRAM_APP_SECRET=abc123...
INSTAGRAM_API_VERSION=v19.0

# ── Image Generation (Stability AI) ──────────────────────────────────────────
# Get a free key at https://platform.stability.ai
STABILITY_API_KEY=sk-...
STABILITY_MODEL=sd3-large        # sd3-large | sd3-medium | core
STABILITY_IMAGE_SIZE=1024x1024

# ── Canva (optional fallback) ─────────────────────────────────────────────────
# CANVA_API_TOKEN=

# ── App Settings ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
MAX_POSTS_PER_PAGE_PER_DAY=5
TREND_SCAN_INTERVAL_HOURS=6
ANALYTICS_INTERVAL_HOURS=12
LEARNING_INTERVAL_HOURS=24

# ── API Server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-this-to-a-strong-random-secret-key
