  {
    "name": "AI Creator OS — Error Handler",
    "nodes": [
      {
        "parameters": {},
        "id": "a1b2c3d4-0006-0006-0006-000000000001",
        "name": "On Workflow Error",
        "type": "n8n-nodes-base.errorTrigger",
        "typeVersion": 1,
        "position": [240, 300]
      },
      {
        "parameters": {
          "assignments": {
            "assignments": [
              {
                "id": "field1",
                "name": "workflow_name",
                "value": "={{ $json.workflow.name }}",
                "type": "string"
              },
              {
                "id": "field2",
                "name": "error_message",
                "value": "={{ $json.execution.error.message }}",
                "type": "string"
              },
              {
                "id": "field3",
                "name": "failed_node",
                "value": "={{ $json.execution.lastNodeExecuted }}",
                "type": "string"
              },
              {
                "id": "field4",
                "name": "execution_id",
                "value": "={{ $json.execution.id }}",
                "type": "string"
              },
              {
                "id": "field5",
                "name": "failed_at",
                "value": "={{ $now.toISO() }}",
                "type": "string"
              }
            ]
          },
          "options": {}
        },
        "id": "a1b2c3d4-0006-0006-0006-000000000002",
        "name": "Format Error",
        "type": "n8n-nodes-base.set",
        "typeVersion": 3.4,
        "position": [480, 300]
      },
      {
        "parameters": {
          "method": "POST",
          "url": "={{ $env.SUPABASE_URL }}/rest/v1/scheduled_jobs",
          "sendHeaders": true,
          "headerParameters": {
            "parameters": [
              {
                "name": "apikey",
                "value": "={{ $env.SUPABASE_KEY }}"
              },
              {
                "name": "Authorization",
                "value": "=Bearer {{ $env.SUPABASE_KEY }}"
              },
              {
                "name": "Content-Type",
                "value": "application/json"
              },
              {
                "name": "Prefer",
                "value": "return=minimal"
              }
            ]
          },
          "sendBody": true,
          "specifyBody": "json",
          "jsonBody": "={\n  \"job_type\": \"error_log\",\n  \"scheduled_at\": \"{{ $json.failed_at }}\",\n  \"executed_at\": \"{{ $json.failed_at }}\",\n  \"status\": \"failed\",\n  \"error_message\": \"[{{ $json.workflow_name }}] {{ $json.failed_node }}: {{ $json.error_message }}\"\n}",
          "options": {
            "timeout": 10000
          }
        },
        "id": "a1b2c3d4-0006-0006-0006-000000000003",
        "name": "Log Error to Supabase",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4.2,
        "position": [720, 300]
      }
    ],
    "connections": {
      "On Workflow Error": {
        "main": [
          [
            {
              "node": "Format Error",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Format Error": {
        "main": [
          [
            {
              "node": "Log Error to Supabase",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    },
    "active": false,
    "settings": {
      "executionOrder": "v1",
      "saveManualExecutions": true
    },
    "versionId": "a1b2c3d4-0006-0006-0006-000000000099",
    "meta": {
      "instanceId": "ai-creator-os"
    },
    "tags": [
      { "name": "ai-creator-os" }
    ]
  }
]
